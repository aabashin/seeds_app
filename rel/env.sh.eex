#!/bin/sh

# Настройка окружения для релиза без распределенного Erlang

# Устанавливаем имя узла без распределенного режима (используем короткое имя)
# Для одиночного контейнера распределение не нужно, но Elixir может требовать узел
export RELEASE_NODE="seeds_app"

# Отключаем cookies для распределенного режима, если не используется
# export RELEASE_COOKIE="seeds_app_cookie"

# Логирование
export RELEASE_LOG_LEVEL="${RELEASE_LOG_LEVEL:-info}"